#include <iostream>
#include <cstring>
#include <stdexcept>

class CallTracker {
private:
    char* contactName;
    char* phoneNumber;
    double maxDuration;
    double minDuration;
    double totalDuration;
    int totalCalls;

public:
    // Конструктор с параметрами
    CallTracker(const char* name, const char* phone) {
        // Исключение 1: Проверка на нулевой указатель имени
        if (!name) throw std::invalid_argument("Имя абонента не может быть NULL");
        // Исключение 2: Проверка на пустую строку имени
        if (std::strlen(name) == 0) throw std::invalid_argument("Имя абонента не может быть пустым");
        // Исключение 3: Проверка номера (минимальная длина)
        if (!phone || std::strlen(phone) < 3) throw std::invalid_argument("Некорректный формат номера телефона");

        contactName = new char[std::strlen(name) + 1];
        std::strcpy(contactName, name);

        phoneNumber = new char[std::strlen(phone) + 1];
        std::strcpy(phoneNumber, phone);

        // Инициализация сводных полей
        maxDuration = 0;
        minDuration = 0;
        totalDuration = 0;
        totalCalls = 0;
    }

    // Деструктор - освобождаем память (Stage 2 пройден!)
    ~CallTracker() {
        delete[] contactName;
        delete[] phoneNumber;
    }

    // Метод вноса информации о новом звонке
    void addCall(double duration) {
        // Исключение 4: Отрицательная длительность
        if (duration < 0) throw std::domain_error("Длительность звонка не может быть отрицательной");
        // Исключение 5: Слишком длинный разговор (защита от ошибок ввода)
        if (duration > 1440) throw std::invalid_argument("Длительность превышает 24 часа. Проверьте данные");

        if (totalCalls == 0) {
            maxDuration = duration;
            minDuration = duration;
        } else {
            if (duration > maxDuration) maxDuration = duration;
            if (duration < minDuration) minDuration = duration;
        }

        totalDuration += duration;
        totalCalls++;
    }

    // Селекторы (Getters)
    double getMaxDuration() const { return maxDuration; }
    double getMinDuration() const { return minDuration; }
    double getTotalDuration() const { return totalDuration; }
    int getTotalCalls() const { 
        // Исключение 6: Попытка получить данные, когда звонков еще не было
        if (totalCalls == 0) throw std::logic_error("Статистика звонков пуста");
        return totalCalls; 
    }

    // Средняя длина разговора
    double getAverageDuration() const {
        if (totalCalls == 0) return 0;
        return totalDuration / totalCalls;
    }

    // Оценка частоты (true - часто, false - нечасто)
    bool isFrequentContact() const {
        return totalDuration > 60;
    }

    // Вывод в консоль
    void displayInfo() const {
        std::cout << "--- Абонент: " << contactName << " ---" << std::endl;
        std::cout << "Номер: " << phoneNumber << std::endl;
        std::cout << "Всего звонков: " << totalCalls << std::endl;
        std::cout << "Общее время: " << totalDuration << " мин." << std::endl;
        std::cout << "Среднее время: " << getAverageDuration() << " мин." << std::endl;
        std::cout << "Рекорд (max): " << maxDuration << " мин." << std::endl;
        std::cout << "Частота: " << (isFrequentContact() ? "Часто" : "Нечасто") << std::endl;
        std::cout << "---------------------------" << std::endl;
    }
};

int main() {
    try {
        // Пример работы
        CallTracker myFriend("Eva", "+79991234567");
        
        myFriend.addCall(15.5);
        myFriend.addCall(50.0);
        myFriend.addCall(5.2);

        myFriend.displayInfo();

    } catch (const std::exception& e) {
        std::cerr << "Ошибка: " << e.what() << std::endl;
    }
    return 0;
}

